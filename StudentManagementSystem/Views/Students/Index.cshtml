@model List<StudentManagementSystem.Models.Student>

@{
    ViewData["Title"] = "Students";
    int totalPages = (int?)ViewData["TotalPages"] ?? 1;
    int currentPage = (int?)ViewData["CurrentPage"] ?? 1;
    string searchTerm = (string?)ViewData["SearchTerm"] ?? "";
    int totalCount = (int?)ViewData["TotalCount"] ?? 0;
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1>@ViewData["Title"]</h1>
            <p class="text-muted">Total Students: <strong>@totalCount</strong></p>
        </div>
        <div class="col-md-6 text-end">
            <button id="refreshBtn" class="btn btn-secondary btn-sm" title="Manually refresh the student list">
                <i class="fas fa-sync-alt"></i> Refresh
            </button>
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus"></i> Add New Student
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Search Form -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-10">
                    <input type="text" id="searchInput" class="form-control" 
                           placeholder="Search by name, email, or phone..." 
                           value="@searchTerm">
                </div>
                <div class="col-md-2">
                    <button type="button" id="clearSearchBtn" class="btn btn-warning w-100" style="display:@(string.IsNullOrEmpty(searchTerm) ? "none" : "block");">
                        <i class="fas fa-times"></i> Clear
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Students Table -->
    @if (Model.Count > 0)
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>DOB</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in Model)
                        {
                            <tr>
                                <td>@student.Id</td>
                                <td>@student.FullName</td>
                                <td>@student.Email</td>
                                <td>@student.PhoneNumber</td>
                                <td>@student.DateOfBirth.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <span class="badge 
                                        @(student.Status == "Active" ? "bg-success" : 
                                          student.Status == "Inactive" ? "bg-warning" : "bg-info")">
                                        @student.Status
                                    </span>
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@student.Id" title="View"
                                       style="display:inline-block;min-width:56px;padding:4px 10px;margin-right:4px;border-radius:12px;background:#0dcaf0;color:#111;text-decoration:none;font-size:12px;font-weight:700;text-align:center;">
                                        View
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@student.Id" title="Edit"
                                       style="display:inline-block;min-width:56px;padding:4px 10px;margin-right:4px;border-radius:12px;background:#ffc107;color:#111;text-decoration:none;font-size:12px;font-weight:700;text-align:center;">
                                        Edit
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@student.Id" title="Delete"
                                       style="display:inline-block;min-width:56px;padding:4px 10px;border-radius:12px;background:#dc3545;color:#fff;text-decoration:none;font-size:12px;font-weight:700;text-align:center;">
                                        Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination justify-content-center">
                    @if (currentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-pageNumber="@(currentPage - 1)" 
                               asp-route-searchTerm="@searchTerm">Previous</a>
                        </li>
                    }

                    <li class="page-item @(currentPage == 1 ? "active" : "")">
                        @if (currentPage == 1)
                        {
                            <span class="page-link">1</span>
                        }
                        else
                        {
                            <a class="page-link" asp-action="Index" asp-route-pageNumber="1" 
                               asp-route-searchTerm="@searchTerm">1</a>
                        }
                    </li>

                    @if (currentPage > 3)
                    {
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    }

                    @{ 
                        int middleStart = Math.Max(2, currentPage - 1);
                        int middleEnd = Math.Min(totalPages - 1, currentPage + 1);
                    }

                    @for (int i = middleStart; i <= middleEnd; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            @if (i == currentPage)
                            {
                                <span class="page-link">@i</span>
                            }
                            else
                            {
                                <a class="page-link" asp-action="Index" asp-route-pageNumber="@i" 
                                   asp-route-searchTerm="@searchTerm">@i</a>
                            }
                        </li>
                    }

                    @if (currentPage < totalPages - 2)
                    {
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    }

                    @if (totalPages > 1)
                    {
                        <li class="page-item @(currentPage == totalPages ? "active" : "")">
                            @if (currentPage == totalPages)
                            {
                                <span class="page-link">@totalPages</span>
                            }
                            else
                            {
                                <a class="page-link" asp-action="Index" asp-route-pageNumber="@totalPages" 
                                   asp-route-searchTerm="@searchTerm">@totalPages</a>
                            }
                        </li>
                    }

                    @if (currentPage < totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-pageNumber="@(currentPage + 1)" 
                               asp-route-searchTerm="@searchTerm">Next</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="alert alert-info text-center" role="alert">
            <i class="fas fa-info-circle"></i>
            <p>No students found.</p>
            @if (!string.IsNullOrEmpty(searchTerm))
            {
                <p>
                    <a asp-action="Index" class="btn btn-link btn-sm">View all students</a>
                </p>
            }
            else
            {
                <p>
                    <a asp-action="Create" class="btn btn-primary btn-sm">Create the first student</a>
                </p>
            }
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Manual refresh button functionality
        document.getElementById('refreshBtn').addEventListener('click', function () {
            window.location.reload();
        });

        // Instant search with AJAX (no page reload)
        const searchInput = document.getElementById('searchInput');
        const clearSearchBtn = document.getElementById('clearSearchBtn');
        let searchTimeout;

        function renderStudentsTable(data) {
            if (!data.success) return;
            
            const tbody = document.querySelector('table tbody');
            if (!tbody) return;

            if (data.data && data.data.length > 0) {
                tbody.innerHTML = data.data.map(student => `
                    <tr>
                        <td>${student.id}</td>
                        <td>${student.fullName}</td>
                        <td>${student.email}</td>
                        <td>${student.phoneNumber}</td>
                        <td>${student.dateOfBirth}</td>
                        <td>
                            <span class="badge ${student.status === 'Active' ? 'bg-success' : student.status === 'Inactive' ? 'bg-warning' : 'bg-info'}">
                                ${student.status}
                            </span>
                        </td>
                        <td>
                            <a href="/Students/Details/${student.id}" title="View"
                               style="display:inline-block;min-width:56px;padding:4px 10px;margin-right:4px;border-radius:12px;background:#0dcaf0;color:#111;text-decoration:none;font-size:12px;font-weight:700;text-align:center;">
                                View
                            </a>
                            <a href="/Students/Edit/${student.id}" title="Edit"
                               style="display:inline-block;min-width:56px;padding:4px 10px;margin-right:4px;border-radius:12px;background:#ffc107;color:#111;text-decoration:none;font-size:12px;font-weight:700;text-align:center;">
                                Edit
                            </a>
                            <a href="/Students/Delete/${student.id}" title="Delete"
                               style="display:inline-block;min-width:56px;padding:4px 10px;border-radius:12px;background:#dc3545;color:#fff;text-decoration:none;font-size:12px;font-weight:700;text-align:center;">
                                Delete
                            </a>
                        </td>
                    </tr>
                `).join('');
            } else {
                tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted">No students found.</td></tr>';
            }

            // Update total count
            const countElement = document.querySelector('p.text-muted strong');
            if (countElement) {
                countElement.textContent = data.totalCount;
            }
        }

        function performSearch(searchTerm) {
            const url = '/api/students/search?' + (searchTerm ? 'searchTerm=' + encodeURIComponent(searchTerm) : '');
            
            fetch(url)
                .then(response => response.json())
                .then(data => renderStudentsTable(data))
                .catch(error => console.error('Search error:', error));
        }

        searchInput.addEventListener('input', function () {
            clearTimeout(searchTimeout);
            const searchTerm = this.value.trim();
            
            // Show/hide clear button
            clearSearchBtn.style.display = searchTerm ? 'block' : 'none';

            // Perform search after user stops typing for 300ms
            searchTimeout = setTimeout(function () {
                performSearch(searchTerm);
            }, 300);
        });

        // Clear search button
        clearSearchBtn.addEventListener('click', function () {
            searchInput.value = '';
            clearSearchBtn.style.display = 'none';
            performSearch('');
        });
    </script>
}
