@model List<StudentManagementSystem.Models.Student>

@{
    ViewData["Title"] = "Students";
    int totalPages = (int?)ViewData["TotalPages"] ?? 1;
    int currentPage = (int?)ViewData["CurrentPage"] ?? 1;
    string searchTerm = (string?)ViewData["SearchTerm"] ?? "";
    int totalCount = (int?)ViewData["TotalCount"] ?? 0;
    int middleStart = Math.Max(2, currentPage - 1);
    int middleEnd = Math.Min(totalPages - 1, currentPage + 1);
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1>@ViewData["Title"]</h1>
            <p class="text-muted">Total Students: <strong>@totalCount</strong></p>
        </div>
        <div class="col-md-6 text-end">
            <button id="refreshBtn" class="btn btn-secondary btn-sm" title="Manually refresh the student list">
                <i class="fas fa-sync-alt"></i> Refresh
            </button>
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus"></i> Add New Student
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Search Form -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="post" asp-action="Search">
                <div class="row g-3">
                    <div class="col-md-8">
                        <input type="text" name="searchTerm" class="form-control"
                               placeholder="Search by name, email, or phone..."
                               value="@searchTerm">
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-search"></i> Search
                        </button>
                    </div>
                    <div class="col-md-2">
                        <button type="submit"
                                formaction="@Url.Action("ClearSearch", "Students")"
                                class="btn btn-warning w-100">
                            <i class="fas fa-times"></i> Clear
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Students Table -->
    <div class="card" id="studentsCard" style="display:@(Model.Count > 0 ? "block" : "none")">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>DOB</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="studentsTableBody">
                    @foreach (var student in Model)
                    {
                        <tr>
                            <td>@student.Id</td>
                            <td>@student.FullName</td>
                            <td>@student.Email</td>
                            <td>@student.PhoneNumber</td>
                            <td>@student.DateOfBirth.ToString("MMM dd, yyyy")</td>
                            <td>
                                <span class="badge 
                                    @(student.Status == "Active" ? "bg-success" : 
                                      student.Status == "Inactive" ? "bg-warning" : "bg-info")">
                                    @student.Status
                                </span>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@student.Id" title="View"
                                   style="display:inline-block;min-width:56px;padding:4px 10px;margin-right:4px;border-radius:12px;background:#0dcaf0;color:#111;text-decoration:none;font-size:12px;font-weight:700;text-align:center;">
                                    View
                                </a>
                                <a asp-action="Edit" asp-route-id="@student.Id" title="Edit"
                                   style="display:inline-block;min-width:56px;padding:4px 10px;margin-right:4px;border-radius:12px;background:#ffc107;color:#111;text-decoration:none;font-size:12px;font-weight:700;text-align:center;">
                                    Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@student.Id" title="Delete"
                                   style="display:inline-block;min-width:56px;padding:4px 10px;border-radius:12px;background:#dc3545;color:#fff;text-decoration:none;font-size:12px;font-weight:700;text-align:center;">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    <nav id="paginationNav" aria-label="Page navigation" class="mt-4" style="display:@(totalPages > 1 && Model.Count > 0 ? "block" : "none")">
        <ul id="paginationList" class="pagination justify-content-center">
            @if (totalPages > 1)
            {
                @if (currentPage > 1)
                {
                    <li class="page-item">
                        <form method="post" asp-action="ChangePage" class="d-inline">
                            <input type="hidden" name="pageNumber" value="@(currentPage - 1)" />
                            <button type="submit" class="page-link">Previous</button>
                        </form>
                    </li>
                }

                <li class="page-item @(currentPage == 1 ? "active" : "")">
                    @if (currentPage == 1)
                    {
                        <span class="page-link">1</span>
                    }
                    else
                    {
                        <form method="post" asp-action="ChangePage" class="d-inline">
                            <input type="hidden" name="pageNumber" value="1" />
                            <button type="submit" class="page-link">1</button>
                        </form>
                    }
                </li>

                @if (currentPage > 3)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                @for (int i = middleStart; i <= middleEnd; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        @if (i == currentPage)
                        {
                            <span class="page-link">@i</span>
                        }
                        else
                        {
                            <form method="post" asp-action="ChangePage" class="d-inline">
                                <input type="hidden" name="pageNumber" value="@i" />
                                <button type="submit" class="page-link">@i</button>
                            </form>
                        }
                    </li>
                }

                @if (currentPage < totalPages - 2)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                <li class="page-item @(currentPage == totalPages ? "active" : "")">
                    @if (currentPage == totalPages)
                    {
                        <span class="page-link">@totalPages</span>
                    }
                    else
                    {
                        <form method="post" asp-action="ChangePage" class="d-inline">
                            <input type="hidden" name="pageNumber" value="@totalPages" />
                            <button type="submit" class="page-link">@totalPages</button>
                        </form>
                    }
                </li>

                @if (currentPage < totalPages)
                {
                    <li class="page-item">
                        <form method="post" asp-action="ChangePage" class="d-inline">
                            <input type="hidden" name="pageNumber" value="@(currentPage + 1)" />
                            <button type="submit" class="page-link">Next</button>
                        </form>
                    </li>
                }
            }
        </ul>
    </nav>

    <div id="emptyState" class="alert alert-info text-center" role="alert" style="display:@(Model.Count > 0 ? "none" : "block")">
        <i class="fas fa-info-circle"></i>
        <p>No students found.</p>
        @if (!string.IsNullOrEmpty(searchTerm))
        {
            <p>
                <form method="post" asp-action="ClearSearch" class="d-inline">
                    <button type="submit" class="btn btn-link btn-sm">View all students</button>
                </form>
            </p>
        }
        else
        {
            <p>
                <a asp-action="Create" class="btn btn-primary btn-sm">Create the first student</a>
            </p>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('refreshBtn').addEventListener('click', function () {
            window.location.reload();
        });
    </script>
}
